{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "IAMRoleForBedrockAgent",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:GetRole",
        "iam:UpdateAssumeRolePolicy",
        "iam:DeleteRole",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:ListRolePolicies"
      ],
      "Resource": "arn:aws:iam::471112767485:role/AmazonBedrockExecutionRoleForAgents_*"
    },
    {
      "Sid": "IAMPassRoleToBedrockOnly",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::471112767485:role/AmazonBedrockExecutionRoleForAgents_*",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "bedrock.amazonaws.com"
        }
      }
    }
  ]
}
